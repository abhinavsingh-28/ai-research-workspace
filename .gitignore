# ============================================
# AI Research Workspace — Git Ignore Rules
# ============================================

# --- Node.js ---
# Downloaded packages (huge folder, can be recreated with `npm install`)
node_modules/
# npm debug logs (generated when npm encounters errors)
npm-debug.log*

# --- Python ---
# Virtual environment (can be recreated with `python3 -m venv venv`)
venv/
# Python bytecode cache (auto-generated compiled files)
__pycache__/
*.pyc
# Python egg/build artifacts
*.egg-info/
dist/
build/

# --- Environment Variables ---
# NEVER commit this file — it contains secrets (API keys, passwords)
.env
# Local environment overrides
.env.local

# --- Uploaded Files ---
# User-uploaded PDFs (data, not code)
uploads/

# --- ChromaDB ---
# Vector database storage (can be re-generated by re-processing papers)
chroma_data/

# --- IDE / Editor ---
# VS Code settings (personal to each developer)
.vscode/
# macOS folder metadata
.DS_Store

# --- Build Output ---
# Vite's production build output (generated with `npm run build`)
client/dist/
