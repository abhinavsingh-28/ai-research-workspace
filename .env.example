# ============================================
# AI Research Workspace — Environment Variables
# ============================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit the .env file — it contains your secrets!

# --- MongoDB ---
# Connection string for your MongoDB database.
# Default for local development (no password needed locally).
MONGODB_URI=mongodb://localhost:27017/ai-research-workspace

# --- JWT Authentication ---
# A random secret string used to sign authentication tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_this

# --- Google Gemini API ---
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server Ports ---
# Which port each service listens on.
SERVER_PORT=5000
ML_SERVICE_PORT=8000

# --- ML Service URL ---
# Where the Node.js backend can reach the Python ML service.
ML_SERVICE_URL=http://localhost:8000
